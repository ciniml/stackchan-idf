diff --git a/src/utility/Speaker_Class.hpp b/src/utility/Speaker_Class.hpp
index d8c7681..6fafadf 100644
--- a/src/utility/Speaker_Class.hpp
+++ b/src/utility/Speaker_Class.hpp
@@ -18,6 +18,28 @@
  #include <driver/i2s.h>
 #endif
 
+// IDF 6.0 dropped the legacy i2s_port_t enum (I2S_NUM_x are still macros)
+// and removed SOC_I2S_NUM / I2S_NUM_MAX. Provide minimal compat for sources
+// that still reference them (Speaker/Mic). Per-target SOC_I2S_NUM is taken
+// from soc_caps in IDF 5.x; for IDF 6 we hard-code based on chip.
+#include <esp_idf_version.h>
+#if ESP_IDF_VERSION >= ESP_IDF_VERSION_VAL(6, 0, 0)
+typedef int i2s_port_t;
+#include <sdkconfig.h>
+#ifndef SOC_I2S_NUM
+ #if defined(CONFIG_IDF_TARGET_ESP32P4)
+  #define SOC_I2S_NUM 3
+ #elif defined(CONFIG_IDF_TARGET_ESP32) || defined(CONFIG_IDF_TARGET_ESP32S3)
+  #define SOC_I2S_NUM 2
+ #else
+  #define SOC_I2S_NUM 1
+ #endif
+#endif
+#ifndef I2S_NUM_MAX
+ #define I2S_NUM_MAX SOC_I2S_NUM
+#endif
+#endif
+
 #endif
 
 #include <atomic>
@@ -76,7 +98,7 @@ namespace m5
     uint8_t task_pinned_core = ~0;
 
     /// I2S port
-    i2s_port_t i2s_port = i2s_port_t::I2S_NUM_0;
+    i2s_port_t i2s_port = (i2s_port_t)I2S_NUM_0;
   };
 
   class Speaker_Class
